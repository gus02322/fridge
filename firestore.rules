rules_version = '2';

// Chaque utilisateur ne peut lire/écrire QUE son propre document users/{uid}.
// À coller dans Firebase Console → Firestore Database → Rules → Publier.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
